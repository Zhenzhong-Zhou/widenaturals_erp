# Database environment configuration
#
# This file defines database- and cache-related configuration used by the server.
# It includes connection details, pool settings, operational tooling paths,
# monitoring thresholds, and Redis cache settings.
#
# This file may reference sensitive values (e.g. passwords) and MUST NOT be committed
# with real credentials.
#
# Defaults for application behavior live in `.env.defaults`.
# This file overrides or supplements those defaults for database infrastructure.
#
# Example values are provided for local development only.

# =====================
# PostgreSQL (connection)
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# =====================
# PostgreSQL (pool & runtime)
# =====================
# Application name shown in pg_stat_activity (optional)
DB_APP_NAME=widenaturals_erp

# Maximum number of clients in the pool (optional, must be a positive integer)
DB_POOL_MAX=10

# Milliseconds a client can sit idle before being closed (optional, 0 = disabled)
DB_IDLE_TIMEOUT=30000

# Milliseconds to wait for a connection before timing out (optional)
DB_CONN_TIMEOUT=5000

# Minimum required PostgreSQL server version (optional)
# Server will warn or refuse to start if the connected PG version is below this
REQUIRED_PG_VERSION=14.0

# =====================
# Database monitoring
# =====================
POOL_MONITOR_INTERVAL=60000
SLOW_QUERY_THRESHOLD=200

# =====================
# Redis
# =====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Optional Redis authentication
REDIS_USERNAME=
REDIS_PASSWORD=

# Redis connection options
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT=5000
REDIS_MAX_RETRIES=3
