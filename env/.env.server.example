# Development server environment overrides
#
# This file contains DEVELOPMENT-ONLY values and placeholders.
# It may reference secrets, but MUST NOT contain real credentials.
#
# Real secrets must be provided via:
# - secret files
# - environment injection
# - container secrets
#
# This file overrides values defined in .env.defaults.

# =====================
# Security (DEV ONLY)
# =====================
# Password hashing pepper (replace with a random string)
PASSWORD_PEPPER=replace-with-password-pepper

# JWT secrets (replace with strong random values)
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-jwt-access-secret
JWT_REFRESH_SECRET=replace-with-jwt-refresh-secret

# JWT / Session lifetimes (seconds)
ACCESS_TOKEN_TTL_SECONDS=900# 15 minutes
REFRESH_TOKEN_TTL_SECONDS=604800# 7 days

# Backup encryption key (DO NOT put the real value here)
# The real key must be provided via a secret file.
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=replace-with-encryption-key

# =====================
# Root Admin (DEV ONLY)
# =====================
# Initial admin bootstrap credentials (development only)
ROOT_ADMIN_EMAIL=admin@example.com
ROOT_ADMIN_PASSWORD=replace-with-admin-password
DEV_ONLY_PASSWORD=replace-with-dev-only-password

# =====================
# AWS (DEV MOCK)
# =====================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-aws-access-key
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-key
AWS_S3_BUCKET_NAME=replace-with-s3-bucket-name

# =====================
# CORS (env-specific)
# =====================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# ALLOWED_IMAGE_HOSTS
# ---------------------------------------------------------------------------
# Comma-separated list of trusted domains that the backend server is allowed
# to download images from when resolving remote image URLs.
#
# Purpose:
#   Prevents SSRF (Server-Side Request Forgery) by restricting outbound
#   image fetch requests to approved infrastructure domains only.
#
# Only include domains that:
#   • Are fully controlled by your organization
#   • Serve raw image files (CDN, S3, CloudFront)
#   • Do NOT redirect to arbitrary external domains
#
# Do NOT include:
#   • Social media domains (Instagram, LinkedIn, etc.)
#   • Marketing websites not under infrastructure control
#   • Client-facing frontend domains
#   • Wildcards (*)
#
ALLOWED_IMAGE_HOSTS=cdn.widenaturals.com,your-bucket-name.s3.amazonaws.com,d123abcd.cloudfront.net
