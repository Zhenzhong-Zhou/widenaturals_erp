{
  "name": "widenaturals-erp-server",
  "version": "2.1.0",
  "description": "Backend server for WIDE Naturals Inc. ERP system. Includes APIs, database access, and business logic.",
  "keywords": [
    "erp",
    "server",
    "api",
    "backend",
    "inventory",
    "orders"
  ],
  "private": true,
  "homepage": "https://github.com/Zhenzhong-Zhou/widenaturals_erp#readme",
  "bugs": {
    "url": "https://github.com/Zhenzhong-Zhou/widenaturals_erp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Zhenzhong-Zhou/widenaturals_erp.git"
  },
  "license": "MIT",
  "author": "Zhenzhong 'Bob' Zhou",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development nodemon src/index.js",
    "dev:trace": "NODE_ENV=development nodemon --trace-warnings src/index.js",
    "create-db": "node src/database/create-db.js",
    "migrate": "knex migrate:latest",
    "rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "create-db:dev": "NODE_ENV=development npm run create-db",
    "migrate:dev": "NODE_ENV=development npm run migrate",
    "rollback:dev": "NODE_ENV=development npm run rollback",
    "seed:dev": "NODE_ENV=development npm run seed",
    "cleanup:dev": "NODE_ENV=development node src/database/seeds/00_cleanup.js",
    "reseed:dev": "NODE_ENV=development node src/database/seeds/00_reseed.js",
    "setup:dev": "npm run create-db:dev && npm run migrate:dev && npm run seed:dev",
    "create-db:test": "NODE_ENV=test npm run create-db",
    "migrate:test": "NODE_ENV=test npm run migrate",
    "rollback:test": "NODE_ENV=test npm run rollback",
    "seed:test": "NODE_ENV=test npm run seed",
    "cleanup:test": "NODE_ENV=test node src/database/seeds/00_cleanup.js",
    "setup:test": "npm run create-db:test && npm run migrate:test && npm run seed:test",
    "migrate:staging": "NODE_ENV=staging npm run migrate",
    "rollback:staging": "NODE_ENV=staging npm run rollback",
    "migrate:prod": "NODE_ENV=production npm run migrate",
    "rollback:prod": "NODE_ENV=production npm run rollback",
    "test": "NODE_ENV=test jest --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.721.0",
    "@dr.pogodin/csurf": "^1.16.2",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "joi": "^18.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lusca": "^1.7.0",
    "mime-types": "^3.0.1",
    "minimist": "^1.2.8",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "p-limit": "^7.2.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.1",
    "ua-parser-js": "^1.0.41",
    "uuid": "^14.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
